{
  "name": "@aaglexx/mcp-man",
  "version": "0.1.19",
  "description": "Registry and inspector for MCP servers — search, inspect, test from CLI or browser",
  "type": "module",
  "bin": {
    "mcp-man": "./dist/cli.js"
  },
  "files": [
    "dist",
    "web/dist",
    "registry"
  ],
  "scripts": {
    "build:cli": "tsc && npm run postbuild:cli",
    "build": "npm run build:cli && vite build --config vite.config.ts",
    "build:web": "vite build --config vite.config.ts",
    "dev:cli": "tsx src/cli.ts",
    "dev:web": "vite --config vite.config.ts",
    "dev": "concurrently \"npm run dev:web\" \"tsx src/cli.ts ui --dev\"",
    "prepublishOnly": "npm run build",
    "postbuild:cli": "node -e \"const fs=require('fs');const f='dist/cli.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/usr/bin/env node')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);}\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  }
}
